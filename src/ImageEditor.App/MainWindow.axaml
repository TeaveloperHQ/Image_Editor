<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="660"
        x:Class="ImageEditor.App.MainWindow"
        Width="940" Height="660"
        Title="Image / PDF Editor">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style Selector="Button.run">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Padding" Value="18,6" />
        </Style>
        <Style Selector="StackPanel.row">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="8" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="12,6">
            <TextBlock x:Name="StatusText" Text="준비됨" Foreground="#CCCCCC" />
        </Border>

        <TabControl Margin="8">

            <!-- ========== 이미지 크기 변경 ========== -->
            <TabItem Header="이미지 크기 변경">
                <StackPanel Margin="16" Spacing="12">
                    <StackPanel Classes="row">
                        <TextBlock Classes="label" Text="이미지 파일" />
                        <TextBox x:Name="ImgInput" Width="380" IsReadOnly="True" Watermark="파일을 선택하세요" />
                        <Button Content="찾아보기…" Click="OnPickImage" />
                    </StackPanel>

                    <StackPanel Classes="row">
                        <RadioButton x:Name="ImgModePixels" GroupName="ImgMode" Content="픽셀 지정" IsChecked="True" />
                        <RadioButton x:Name="ImgModePercent" GroupName="ImgMode" Content="백분율" />
                    </StackPanel>

                    <StackPanel Classes="row" IsVisible="{Binding #ImgModePixels.IsChecked}">
                        <TextBlock Classes="label" Text="크기(px)" />
                        <TextBlock Text="너비" VerticalAlignment="Center" />
                        <TextBox x:Name="ImgWidth" Width="80" Text="800" />
                        <TextBlock Text="높이" VerticalAlignment="Center" />
                        <TextBox x:Name="ImgHeight" Width="80" Text="0" />
                        <CheckBox x:Name="ImgKeepAspect" Content="비율 유지" IsChecked="True" />
                    </StackPanel>

                    <StackPanel Classes="row" IsVisible="{Binding #ImgModePercent.IsChecked}">
                        <TextBlock Classes="label" Text="백분율(%)" />
                        <TextBox x:Name="ImgPercent" Width="80" Text="50" />
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Foreground="#888"
                               Text="* 비율 유지 시 높이를 0으로 두면 너비에 맞춰 자동 계산됩니다." />

                    <Button Classes="run" Content="크기 변경 후 저장" Click="OnResizeImage" />
                </StackPanel>
            </TabItem>

            <!-- ========== PDF 결합 ========== -->
            <TabItem Header="PDF 결합">
                <StackPanel Margin="16" Spacing="12">
                    <StackPanel Classes="row">
                        <Button Content="PDF 추가…" Click="OnAddMergeFiles" />
                        <Button Content="선택 삭제" Click="OnRemoveMergeFile" />
                        <Button Content="위로" Click="OnMoveMergeUp" />
                        <Button Content="아래로" Click="OnMoveMergeDown" />
                        <Button Content="전체 비우기" Click="OnClearMerge" />
                    </StackPanel>
                    <ListBox x:Name="MergeList" Height="260" SelectionMode="Single" />
                    <TextBlock Foreground="#888" Text="* 위에서 아래 순서대로 결합됩니다." />
                    <Button Classes="run" Content="결합하여 저장" Click="OnMergePdf" />
                </StackPanel>
            </TabItem>

            <!-- ========== PDF 분해 / 추출 ========== -->
            <TabItem Header="PDF 분해·추출">
                <StackPanel Margin="16" Spacing="12">
                    <StackPanel Classes="row">
                        <TextBlock Classes="label" Text="PDF 파일" />
                        <TextBox x:Name="SplitInput" Width="380" IsReadOnly="True" Watermark="파일을 선택하세요" />
                        <Button Content="찾아보기…" Click="OnPickSplitPdf" />
                    </StackPanel>
                    <TextBlock x:Name="SplitPageInfo" Foreground="#888" Text="" />

                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="① 모든 페이지를 한 장씩 분해" FontWeight="Bold" />
                            <Button Content="페이지별로 분해하여 폴더에 저장" Click="OnSplitAll" />
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="② 특정 페이지만 추출" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <TextBlock Classes="label" Text="페이지 범위" />
                                <TextBox x:Name="ExtractRange" Width="220" Watermark="예: 1-3,5,8-10" />
                            </StackPanel>
                            <Button Content="추출하여 저장" Click="OnExtractPages" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ========== PDF 크기 / 용량 ========== -->
            <TabItem Header="PDF 크기/용량">
                <StackPanel Margin="16" Spacing="12">
                    <StackPanel Classes="row">
                        <TextBlock Classes="label" Text="PDF 파일" />
                        <TextBox x:Name="PdfSizeInput" Width="380" IsReadOnly="True" Watermark="파일을 선택하세요" />
                        <Button Content="찾아보기…" Click="OnPickPdfSize" />
                    </StackPanel>
                    <TextBlock x:Name="PdfSizeInfo" Foreground="#888" Text="" />

                    <!-- 용량 줄이기 -->
                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="용량 줄이기" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <TextBlock Text="조금" VerticalAlignment="Center" Foreground="#888" />
                                <Slider x:Name="ReduceSlider" Width="300" Minimum="10" Maximum="90" Value="50"
                                        TickFrequency="10" IsSnapToTickEnabled="True" />
                                <TextBlock Text="많이" VerticalAlignment="Center" Foreground="#888" />
                                <TextBlock Text="{Binding #ReduceSlider.Value}" VerticalAlignment="Center" />
                                <TextBlock Text="% 줄이기" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Foreground="#888" TextWrapping="Wrap"
                                       Text="* 슬라이더를 오른쪽으로 옮길수록 용량이 더 줄지만 사진 화질은 떨어집니다. 스캔·사진이 많은 PDF에 효과가 크고, 글자만 있는 PDF는 거의 줄지 않습니다." />
                            <Button Content="용량 줄여 저장" Click="OnCompressPdf" HorizontalAlignment="Left" />
                            <TextBlock x:Name="CompressResult" Foreground="#7CD992" Text="" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- 용지 크기 변경 -->
                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="용지 크기 변경" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <TextBlock Classes="label" Text="용지 크기" />
                                <ComboBox x:Name="PageSizeCombo" Width="160" SelectedIndex="0">
                                    <ComboBoxItem>A4</ComboBoxItem>
                                    <ComboBoxItem>A3</ComboBoxItem>
                                    <ComboBoxItem>A5</ComboBoxItem>
                                    <ComboBoxItem>Letter</ComboBoxItem>
                                    <ComboBoxItem>Legal</ComboBoxItem>
                                </ComboBox>
                                <CheckBox x:Name="PdfKeepAspect" Content="비율 유지(여백 추가)" IsChecked="True" />
                            </StackPanel>
                            <TextBlock Foreground="#888" TextWrapping="Wrap"
                                       Text="* 모든 페이지를 선택한 용지 크기에 맞춰 다시 그립니다." />
                            <Button Content="용지 크기 변경 후 저장" Click="OnResizePdf" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ========== 이미지 편집 ========== -->
            <TabItem Header="이미지 편집">
                <DockPanel Margin="8">

                    <!-- 우측 도구 패널 -->
                    <ScrollViewer DockPanel.Dock="Right" Width="250" Margin="8,0,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Classes="row">
                                <Button Content="불러오기" Click="OnEditLoad" />
                                <Button Content="저장…" Click="OnEditSave" />
                            </StackPanel>

                            <Separator />
                            <TextBlock Text="회전 / 반전" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <Button Content="↺ 90°" Click="OnEditRotateLeft" />
                                <Button Content="↻ 90°" Click="OnEditRotateRight" />
                                <Button Content="좌우" Click="OnEditFlipH" />
                                <Button Content="상하" Click="OnEditFlipV" />
                            </StackPanel>

                            <Separator />
                            <TextBlock Text="작업 모드" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <RadioButton x:Name="ModeCrop" GroupName="EditMode" Content="자르기" IsChecked="True" />
                                <RadioButton x:Name="ModeText" GroupName="EditMode" Content="텍스트" />
                                <RadioButton x:Name="ModeImage" GroupName="EditMode" Content="그림" />
                            </StackPanel>

                            <!-- 자르기 -->
                            <StackPanel Spacing="6" IsVisible="{Binding #ModeCrop.IsChecked}">
                                <TextBlock Foreground="#888" TextWrapping="Wrap"
                                           Text="미리보기에서 드래그하여 영역을 선택한 뒤 아래 버튼을 누르세요." />
                                <Button Content="선택 영역 자르기" Click="OnEditCrop" />
                            </StackPanel>

                            <!-- 텍스트 -->
                            <StackPanel Spacing="6" IsVisible="{Binding #ModeText.IsChecked}">
                                <TextBlock Foreground="#888" TextWrapping="Wrap"
                                           Text="내용·서식을 정하고 미리보기를 클릭하면 그 위치에 글자가 들어갑니다." />
                                <TextBox x:Name="TextContent" Watermark="넣을 텍스트" Text="텍스트" />
                                <StackPanel Classes="row">
                                    <ComboBox x:Name="FontCombo" Width="150" />
                                    <Button Content="폰트 추가…" Click="OnAddFont" />
                                </StackPanel>
                                <StackPanel Classes="row">
                                    <TextBlock Text="크기" VerticalAlignment="Center" />
                                    <TextBox x:Name="TextSize" Width="60" Text="32" />
                                    <TextBlock Text="색상" VerticalAlignment="Center" />
                                    <TextBox x:Name="TextColor" Width="90" Text="#FF0000" />
                                </StackPanel>
                            </StackPanel>

                            <!-- 그림 -->
                            <StackPanel Spacing="6" IsVisible="{Binding #ModeImage.IsChecked}">
                                <TextBlock Foreground="#888" TextWrapping="Wrap"
                                           Text="얹을 이미지를 고르고 미리보기를 클릭하면 그 위치에 들어갑니다. (크기 0=원본)" />
                                <Button Content="이미지 선택…" Click="OnPickOverlay" />
                                <TextBlock x:Name="OverlayName" Foreground="#888" Text="(선택 안 됨)" />
                                <StackPanel Classes="row">
                                    <TextBlock Text="너비" VerticalAlignment="Center" />
                                    <TextBox x:Name="OverlayW" Width="60" Text="0" />
                                    <TextBlock Text="높이" VerticalAlignment="Center" />
                                    <TextBox x:Name="OverlayH" Width="60" Text="0" />
                                </StackPanel>
                            </StackPanel>

                            <Separator />
                            <TextBlock x:Name="EditInfo" Foreground="#888" Text="이미지를 불러오세요." TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 미리보기 -->
                    <Border Background="#252525" CornerRadius="4">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="EditCanvas" Background="Transparent"
                                    PointerPressed="OnCanvasPressed"
                                    PointerMoved="OnCanvasMoved"
                                    PointerReleased="OnCanvasReleased">
                                <Image x:Name="EditImage" Canvas.Left="0" Canvas.Top="0" />
                                <Rectangle x:Name="CropRect" IsVisible="False"
                                           Stroke="#00B4FF" StrokeThickness="1.5"
                                           StrokeDashArray="4,3" Fill="#3300B4FF" />
                            </Canvas>
                        </ScrollViewer>
                    </Border>

                </DockPanel>
            </TabItem>

            <!-- ========== PDF 편집 ========== -->
            <TabItem Header="PDF 편집">
                <DockPanel Margin="8">

                    <ScrollViewer DockPanel.Dock="Right" Width="270" Margin="8,0,0,0">
                        <StackPanel Spacing="10">
                            <StackPanel Classes="row">
                                <Button Content="불러오기" Click="OnPdfEditLoad" />
                                <Button Content="저장…" Click="OnPdfEditSave" />
                            </StackPanel>

                            <Separator />
                            <TextBlock Text="페이지" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <Button Content="◀ 이전" Click="OnPdfPrevPage" />
                                <TextBlock x:Name="PdfPageLabel" Text="- / -" VerticalAlignment="Center" MinWidth="60"
                                           HorizontalAlignment="Center" TextAlignment="Center" />
                                <Button Content="다음 ▶" Click="OnPdfNextPage" />
                            </StackPanel>

                            <Separator />
                            <TextBlock Text="얹을 내용" FontWeight="Bold" />
                            <StackPanel Classes="row">
                                <RadioButton x:Name="ModePdfText" GroupName="PdfMode" Content="텍스트" IsChecked="True" />
                                <RadioButton x:Name="ModePdfImage" GroupName="PdfMode" Content="이미지·서명" />
                            </StackPanel>

                            <StackPanel Spacing="6" IsVisible="{Binding #ModePdfText.IsChecked}">
                                <TextBlock Foreground="#888" TextWrapping="Wrap"
                                           Text="내용·서식을 정하고 페이지에서 원하는 위치를 클릭하세요." />
                                <TextBox x:Name="PdfTextContent" Watermark="넣을 텍스트" Text="확인" />
                                <StackPanel Classes="row">
                                    <ComboBox x:Name="PdfFontCombo" Width="150" />
                                    <Button Content="폰트 추가…" Click="OnPdfAddFont" />
                                </StackPanel>
                                <StackPanel Classes="row">
                                    <TextBlock Text="크기" VerticalAlignment="Center" />
                                    <TextBox x:Name="PdfTextSize" Width="55" Text="24" />
                                    <TextBlock Text="색상" VerticalAlignment="Center" />
                                    <TextBox x:Name="PdfTextColor" Width="85" Text="#FF0000" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="6" IsVisible="{Binding #ModePdfImage.IsChecked}">
                                <TextBlock Foreground="#888" TextWrapping="Wrap"
                                           Text="이미지/서명 파일을 고르고 페이지에서 위치를 클릭하세요. (너비 0 = 원본)" />
                                <Button Content="이미지 선택…" Click="OnPickPdfOverlay" />
                                <TextBlock x:Name="PdfOverlayName" Foreground="#888" Text="(선택 안 됨)" />
                                <StackPanel Classes="row">
                                    <TextBlock Text="너비" VerticalAlignment="Center" />
                                    <TextBox x:Name="PdfOverlayW" Width="70" Text="120" />
                                    <TextBlock Text="pt" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <Separator />
                            <TextBlock x:Name="PdfEditInfo" Foreground="#888" Text="PDF를 불러오세요." TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Background="#252525" CornerRadius="4">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="PdfCanvas" Background="Transparent" PointerPressed="OnPdfCanvasPressed">
                                <Image x:Name="PdfPageImage" Canvas.Left="0" Canvas.Top="0" />
                            </Canvas>
                        </ScrollViewer>
                    </Border>

                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
